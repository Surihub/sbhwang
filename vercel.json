{
  "buildCommand": "hugo --gc --minify",
  "installCommand": "curl -L -o /tmp/hugo.tar.gz https://github.com/gohugoio/hugo/releases/download/v0.128.0/hugo_extended_0.128.0_linux-amd64.tar.gz && tar -xzf /tmp/hugo.tar.gz -C /usr/local/bin/ hugo",
  "outputDirectory": "public",
  "framework": "hugo",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/$1"
    }
  ]
}
